// spell-checker:words esbenp otbs
{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },

  "files.exclude": {
    "**/.DS_Store": true
  },
  "files.associations": {
    "LICENSE": "plaintext"
  },

  // settings for extensions below

  // spell checker settings
  "cSpell.ignorePaths": [".git"],
  "cSpell.language": "en-US",
  "cSpell.flagWords": ["colour"], // spell-checker:disable-line
  "cSpell.words": ["endgroup", "iisexpress", "pwsh"],

  // markdownlint extension settings
  "markdownlint.config": {
    "MD007": { "indent": 4 }
  },

  // redhat xml extension settings
  "xml.format.maxLineWidth": 0,

  // powershell settings
  "powershell.codeFormatting.alignPropertyValuePairs": false,
  "powershell.codeFormatting.pipelineIndentationStyle": "IncreaseIndentationForFirstPipeline",
  "powershell.codeFormatting.preset": "OTBS", // "One True Brace Style" a.k.a. K&R brace style, https://github.com/PoshCode/PowerShellPracticeAndStyle/issues/81#issuecomment-285835313
  "powershell.codeFormatting.useCorrectCasing": true,

  // language associations
  "[xml]": {
    "files.trimFinalNewlines": false
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
